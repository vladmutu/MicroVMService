#!/bin/sh
# /run_at_start/init — Production MicroVM Init
# Agent is enabled; all output is streamed to /dev/console

echo "[init] booting..." > /dev/console

# --- Mount core filesystems ---
mount -t proc proc /proc        > /dev/console 2>&1
mount -t sysfs sysfs /sys       > /dev/console 2>&1
mount -t devtmpfs devtmpfs /dev > /dev/console 2>&1 || true

mkdir -p /root /tmp
chmod 1777 /tmp

# --- Fix critical device nodes ---
[ -e /dev/null ] || mknod -m 666 /dev/null c 1 3
chmod 666 /dev/null
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts -o mode=620,ptmxmode=666 > /dev/console 2>&1 || true

# --- FIX 1: Disable IPv6 entirely to prevent routing blackholes ---
sysctl -w net.ipv6.conf.all.disable_ipv6=1 > /dev/console 2>&1
sysctl -w net.ipv6.conf.default.disable_ipv6=1 > /dev/console 2>&1

# --- Network setup ---
echo "[init] bringing up loopback..." > /dev/console
ip link set lo up > /dev/console 2>&1

echo "[init] waiting for eth0..." > /dev/console
count=0
while [ $count -lt 20 ]; do
    if ip link show eth0 > /dev/null 2>&1; then
        echo "[init] eth0 found" > /dev/console
        break
    fi
    sleep 0.1
    count=$((count+1))
done

if ip link show eth0 > /dev/null 2>&1; then
    ip link set eth0 up > /dev/console 2>&1

    # Read IP config from kernel cmdline (injected by host via boot_args)
    FC_IP=$(grep -o 'fc_ip=[^ ]*' /proc/cmdline | cut -d= -f2)
    FC_GW=$(grep -o 'fc_gw=[^ ]*' /proc/cmdline | cut -d= -f2)
    FC_MASK=$(grep -o 'fc_mask=[^ ]*' /proc/cmdline | cut -d= -f2)

    if [ -n "$FC_IP" ] && [ -n "$FC_GW" ] && [ -n "$FC_MASK" ]; then
        echo "[init] configuring eth0: ip=$FC_IP/$FC_MASK gw=$FC_GW" > /dev/console
        ip addr add "$FC_IP/$FC_MASK" dev eth0 > /dev/console 2>&1
        ip route add default via "$FC_GW" > /dev/console 2>&1
        echo "[init] eth0 configured" > /dev/console
    else
        echo "[init] ERROR: missing fc_ip/fc_gw/fc_mask in cmdline" > /dev/console
    fi
else
    echo "[init] ERROR: eth0 never appeared" > /dev/console
fi

echo "nameserver 8.8.8.8" > /etc/resolv.conf
echo "nameserver 1.1.1.1" >> /etc/resolv.conf
echo "[init] /etc/resolv.conf written" > /dev/console

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root

# --- FIX 2: Start Entropy Daemon (Crucial for HTTPS/pip/npm) ---
echo "[init] Starting haveged..." > /dev/console
if command -v haveged >/dev/null 2>&1; then
    haveged -w 1024
    echo "[init] haveged is running in the background." > /dev/console
else
    echo "[init] WARNING: haveged not found! TLS connections may hang." > /dev/console
fi

# --- Agent Startup ---
echo "[init] Starting Agent..." > /dev/console
/usr/bin/python3 -u /opt/agent.py > /dev/console 2>&1
AGENT_EXIT=$?
echo "[init] agent exited with code $AGENT_EXIT" > /dev/console

# --- Shutdown ---
sync
sleep 2
poweroff -f